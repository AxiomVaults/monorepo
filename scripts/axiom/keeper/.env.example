# Keeper Bot — Production Environment
# Copy to .env and fill in values

# Required: private key of the keeper wallet (must have OPERATOR_ROLE on MultiStrategyManager)
KEEPER_PRIVATE_KEY=0x...

# Optional: Flow EVM RPC (defaults to public mainnet RPC)
RPC_URL=https://mainnet.evm.nodes.onflow.org

# Optional: path to deployed addresses JSON (defaults to deployed-mainnet.json)
DEPLOYED_JSON=./deployed-mainnet.json

# Optional: set to "true" to read APYs and log without sending any transactions
DRY_RUN=false

# ─── Cron setup (hourly) ──────────────────────────────────────────────────────
# Add to crontab with:  crontab -e
# 0 * * * * cd /path/to/scripts/axiom/keeper && node keeperBot.js >> keeper.log 2>&1
